#!/usr/bin/env python3
import json
import sys
import urllib.error
import urllib.request
from pathlib import Path

import faiss
import numpy as np
from sentence_transformers import SentenceTransformer


BASE_DIR = Path(__file__).parent
PROMPTS_DIR = BASE_DIR / "prompts"
INDEX_DIR = BASE_DIR / "index"

SYSTEM_PROMPT_PATH = PROMPTS_DIR / "system.txt"
ANSWER_PROMPT_PATH = PROMPTS_DIR / "answer.txt"
FAISS_PATH = INDEX_DIR / "hoa_index.faiss"
META_PATH = INDEX_DIR / "hoa_index_meta.json"

OLLAMA_URL = "http://localhost:11434/api/chat"
CHAT_MODEL = "phi4:14b"
EMBED_MODEL = "all-MiniLM-L6-v2"
TOP_K = 6


def load_text(path: Path) -> str:
    return path.read_text(encoding="utf-8")


def load_index() -> tuple[faiss.Index, list[dict]]:
    if not FAISS_PATH.exists() or not META_PATH.exists():
        raise FileNotFoundError(
            "Index files not found. Run ingest_hoa_docs.py first."
        )
    index = faiss.read_index(str(FAISS_PATH))
    meta = json.loads(META_PATH.read_text(encoding="utf-8"))
    return index, meta


def retrieve(query: str, embed_model: SentenceTransformer, index: faiss.Index, meta: list[dict], top_k: int = TOP_K) -> list[dict]:
    query_vec = embed_model.encode([query], normalize_embeddings=True)
    query_vec = np.array(query_vec, dtype="float32")

    scores, ids = index.search(query_vec, top_k)
    results: list[dict] = []

    for score, idx in zip(scores[0], ids[0]):
        if idx < 0 or idx >= len(meta):
            continue
        item = dict(meta[idx])
        item["score"] = float(score)
        results.append(item)

    return results


def build_user_prompt(question: str, retrieved_chunks: list[dict], answer_template: str) -> str:
    excerpts = []
    for i, chunk in enumerate(retrieved_chunks, start=1):
        excerpts.append(
            f"[Excerpt {i}]\n"
            f"Source: {chunk['source_file']}\n"
            f"Chunk: {chunk['chunk_index']}\n"
            f"Text: {chunk['text']}\n"
        )

    return (
        f"{answer_template.strip()}\n\n"
        f"USER QUESTION / GOAL:\n{question.strip()}\n\n"
        f"RELEVANT HOA DOCUMENT EXCERPTS:\n\n"
        + "\n".join(excerpts)
    )


def call_ollama(system_prompt: str, user_prompt: str, model: str = CHAT_MODEL) -> str:
    payload = json.dumps(
        {
            "model": model,
            "stream": False,
            "messages": [
                {"role": "system", "content": system_prompt},
                {"role": "user", "content": user_prompt},
            ],
        }
    ).encode("utf-8")

    req = urllib.request.Request(
        OLLAMA_URL,
        data=payload,
        headers={"Content-Type": "application/json"},
        method="POST",
    )

    try:
        with urllib.request.urlopen(req, timeout=180) as resp:
            data = json.loads(resp.read())
            return data["message"]["content"].strip()
    except urllib.error.URLError as e:
        print(f"[error] Could not reach Ollama at {OLLAMA_URL}")
        print(f"[error] {e}")
        sys.exit(1)


def main() -> None:
    print("HOA AI")
    print(f"Model: {CHAT_MODEL}")
    print("Type 'quit' to exit.\n")

    system_prompt = load_text(SYSTEM_PROMPT_PATH)
    answer_template = load_text(ANSWER_PROMPT_PATH)
    index, meta = load_index()
    embed_model = SentenceTransformer(EMBED_MODEL)

    while True:
        try:
            user_input = input("You: ").strip()
        except (EOFError, KeyboardInterrupt):
            print("\nGoodbye.")
            break

        if not user_input:
            continue
        if user_input.lower() == "quit":
            print("Goodbye.")
            break

        retrieved = retrieve(user_input, embed_model, index, meta, top_k=TOP_K)
        user_prompt = build_user_prompt(user_input, retrieved, answer_template)
        answer = call_ollama(system_prompt, user_prompt)

        print(f"\nAssistant:\n{answer}\n")


if __name__ == "__main__":
    main()