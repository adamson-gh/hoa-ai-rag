#!/usr/bin/env python3
import json
import os
import re
import sys
import urllib.error
import urllib.request
from datetime import datetime
from pathlib import Path

import faiss
import numpy as np
from sentence_transformers import SentenceTransformer

BASE_DIR = Path(__file__).parent

if len(sys.argv) > 1:
    HOA_NAME = sys.argv[1].strip().lower()
else:
    HOA_NAME = "milestone"

DATASET_DIR = BASE_DIR / "data" / HOA_NAME
INDEX_DIR = DATASET_DIR / "index"
LOG_DIR = DATASET_DIR / "logs"

FAISS_PATH = INDEX_DIR / "hoa_index.faiss"
META_PATH = INDEX_DIR / "hoa_index_meta.json"
DEBUG_LOG_PATH = LOG_DIR / "hoa_debug_log.jsonl"

OLLAMA_URL = "http://localhost:11434/api/chat"
CHAT_MODEL = "phi4:14b"
EMBED_MODEL = "all-MiniLM-L6-v2"

TOP_K = 10
MIN_SCORE = 0.30
MIN_CHUNK_SCORE = 0.35
MAX_CONTEXT_CHUNKS = 4
MAX_PER_DOCUMENT = 2
DEBUG_SHOW_EXCERPTS = True

print(f"[config] HOA_NAME={HOA_NAME}")
print(f"[config] INDEX_DIR={INDEX_DIR}")
print(f"[config] LOG_DIR={LOG_DIR}")

SYSTEM_PROMPT = """You are an HOA document assistant.

Answer only from the retrieved HOA excerpts.
Do not invent rules.
Do not overstate conclusions.

If the excerpts support only a conditional answer, say so clearly.
Use phrases like:
- "appears to"
- "likely"
- "if the document treats X as Y"
- "the excerpts do not fully define this"

If the excerpts do not clearly answer the question, say that plainly.

Format your answer as:
1. Direct answer
2. What the documents say
3. Practical options
4. Uncertainty / limits

Always cite sources inline using the provided source and page.
Do not claim certainty beyond the text.
"""


def load_index() -> tuple[faiss.Index, list[dict]]:
    if not FAISS_PATH.exists() or not META_PATH.exists():
        raise FileNotFoundError("Index files not found. Run ingest_hoa_docs.py first.")
    index = faiss.read_index(str(FAISS_PATH))
    meta = json.loads(META_PATH.read_text(encoding="utf-8"))
    return index, meta


def normalize_query(query: str) -> str:
    q = query.strip().lower()

    replacements = {
        " part ": " park ",
        " vechicle ": " vehicle ",
        " tennant ": " tenant ",
        " assesment ": " assessment ",
        " assesments ": " assessments ",
    }

    q = f" {q} "
    for old, new in replacements.items():
        q = q.replace(old, new)

    return " ".join(q.split())


def tokenize(text: str) -> set[str]:
    return set(re.findall(r"[a-z0-9]+", text.lower()))


def lexical_overlap_score(query: str, item: dict) -> float:
    query_tokens = tokenize(query)
    if not query_tokens:
        return 0.0

    text_tokens = tokenize(item.get("text", ""))
    keyword_tokens = set(k.lower() for k in item.get("keywords", []))

    text_overlap = len(query_tokens & text_tokens)
    keyword_overlap = len(query_tokens & keyword_tokens)

    score = 0.0
    score += min(text_overlap, 6) * 0.015
    score += min(keyword_overlap, 4) * 0.03

    score /= max(1.0, min(len(query_tokens), 8) / 4)

    return score


def section_title_score(query: str, item: dict) -> float:
    query_tokens = tokenize(query)
    if not query_tokens:
        return 0.0

    section_title = item.get("section_title") or ""
    heading_candidates = item.get("heading_candidates") or []

    title_tokens = tokenize(section_title)
    overlap = len(query_tokens & title_tokens)

    score = min(overlap, 4) * 0.04

    for heading in heading_candidates[:3]:
        heading_tokens = tokenize(heading)
        score += min(len(query_tokens & heading_tokens), 3) * 0.015

    return score

def tokenize_list(text: str) -> list[str]:
    return re.findall(r"[a-z0-9]+", text.lower())


def analyze_query(question: str) -> dict:
    q = question.strip()
    q_norm = normalize_query(q)
    tokens = set(tokenize_list(q_norm))

    concepts = set()
    preferred_doc_types = set()

    if {"park", "parking", "vehicle", "van", "street", "overnight"} & tokens:
        concepts.update({"parking", "vehicle", "street", "rules"})
        preferred_doc_types.update({"ccrs", "policy"})

    if {"lease", "leasing", "rent", "rental", "tenant"} & tokens:
        concepts.update({"leasing", "tenant", "owner", "restrictions"})
        preferred_doc_types.add("ccrs")

    if {"assessment", "assessments", "dues", "late", "delinquent", "lien"} & tokens:
        concepts.update({"assessments", "lien", "late fee", "collection"})
        preferred_doc_types.update({"ccrs", "policy", "bylaws"})

    if {"trash", "garbage", "recycling", "recycle", "waste"} & tokens:
        concepts.update({"trash", "garbage", "recycling", "waste"})
        preferred_doc_types.add("policy")

    if {"pet", "pets", "dog", "dogs", "cat", "cats", "bark", "barking"} & tokens:
        concepts.update({"animals", "pets", "nuisance"})
        preferred_doc_types.update({"ccrs", "policy"})

    if {"music", "loud", "noise", "quiet", "nuisance", "annoy"} & tokens:
        concepts.update({"nuisance", "noise", "quiet enjoyment"})
        preferred_doc_types.update({"ccrs", "policy"})

    if {"outside", "condo", "condominium", "common", "ground", "area"} & tokens:
        concepts.update({"common area", "hoa area", "exclusive use", "private uses"})
        preferred_doc_types.update({"ccrs", "policy"})

    if {"approval", "approve", "architectural", "exterior", "acc"} & tokens:
        concepts.update({"architectural control", "approval", "acc"})
        preferred_doc_types.update({"ccrs", "policy"})

    if {"violate", "violation", "violations", "fine", "fines", "hearing", "notice", "enforcement"} & tokens:
        concepts.update({"violation", "fines", "hearing", "notice", "enforcement"})
        preferred_doc_types.update({"ccrs", "policy"})

    return {
        "original_question": q,
        "normalized_question": q_norm,
        "concepts": sorted(concepts),
        "preferred_doc_types": sorted(preferred_doc_types),
    }

def retrieve(
    query: str,
    embed_model: SentenceTransformer,
    index: faiss.Index,
    meta: list[dict],
    top_k: int = TOP_K,
) -> list[dict]:
    query_vec = embed_model.encode([query], normalize_embeddings=True)
    query_vec = np.array(query_vec, dtype="float32")
    scores, ids = index.search(query_vec, top_k)

    results = []
    for score, idx in zip(scores[0], ids[0]):
        if idx < 0 or idx >= len(meta):
            continue
        item = dict(meta[idx])
        item["score"] = float(score)
        item["boosted_score"] = float(score)
        results.append(item)
    return results


def retrieve_with_analysis(
    analysis: dict,
    embed_model: SentenceTransformer,
    index: faiss.Index,
    meta: list[dict],
    top_k: int = TOP_K,
) -> list[dict]:
    query_variants = []

    original_q = analysis["original_question"]
    normalized_q = analysis["normalized_question"]
    concepts = analysis["concepts"]

    query_variants.append((original_q, 1.0))

    if normalized_q != original_q:
        query_variants.append((normalized_q, 0.95))
    else:
        query_variants.append((normalized_q, 0.95))

    if concepts:
        concept_query = f"{normalized_q} {' '.join(concepts)}"
        query_variants.append((concept_query, 0.90))
        query_variants.append((" ".join(concepts), 0.80))

    merged: dict[str, dict] = {}

    for query_text, weight in query_variants:
        partial = retrieve(query_text, embed_model, index, meta, top_k=top_k)

        for item in partial:
            item = dict(item)
            item["score"] = float(item["score"] * weight)
            item["boosted_score"] = float(item["score"])

            key = item["id"]
            existing = merged.get(key)
            if existing is None or item["score"] > existing["score"]:
                merged[key] = item

    return sorted(merged.values(), key=lambda x: x["score"], reverse=True)


def boost_score_milestone(query: str, item: dict, boost: float) -> float:
    q = query.lower()
    source_file = item.get("source_file", "").lower()

    if any(term in q for term in ["parking", "park", "vehicle", "van", "overnight"]):
        if "trash-disposal" in source_file or "trash_disposal" in source_file or "policy-trash-disposal" in source_file:
            boost -= 0.12

        if "p.i.c.a.e" in source_file or "covenant6641909" in source_file:
            boost -= 0.08

    return boost


def boost_score_arora(query: str, item: dict, boost: float) -> float:
    q = query.lower()
    text = item.get("text", "").lower()
    source_file = item.get("source_file", "").lower()
    doc_type = item.get("doc_type", "")

    # Parking / vehicle questions: prefer master rules + declaration, demote unrelated docs
    if any(term in q for term in ["parking", "park", "vehicle", "van", "overnight", "street"]):
        if "masterrules" in source_file:
            boost += 0.06
        if "public street parking laws" in source_file:
            boost += 0.04

    # Condo / HOA-area / common-ground questions:
    # favor HOA/common-area restrictions, demote lot-based structure rules unless explicitly asking about structures
    if any(term in q for term in ["common ground", "common area", "hoa area", "outside my condo", "outside the building", "outside of my condo"]):
        if any(term in text for term in ["hoa area", "common area", "exclusive use", "private uses", "storage facilities", "personal gardens"]):
            boost += 0.22

        if not any(term in q for term in ["shed", "gazebo", "deck", "greenhouse", "pergola", "trellis", "structure"]):
            if any(term in text for term in ["rear of lots", "rear of lots only", "sheds", "green houses", "gazebos", "pergolas", "trellises"]):
                boost -= 0.18

    # Trash enclosure / shared trash area questions
    if any(term in q for term in ["trash area", "trash areas", "trash enclosure", "trash enclosures", "shared trash", "shared trash area", "central trash", "collection area"]):
        if any(term in text for term in ["central trash collection area", "trash enclosure", "trash enclosures", "association may regulate the use"]):
            boost += 0.22

        if any(term in text for term in ["clubhouse", "pool entrance", "renters", "rental"]):
            boost -= 0.08

    # Pet / waste / poop questions
    if any(term in q for term in ["pet", "pets", "dog", "poop", "waste", "pet waste", "dog poop"]):
        if any(term in text for term in ["animals", "nuisance", "cleanliness", "litter", "debris"]):
            boost += 0.12

    # Leasing questions: prefer declarations and actual leasing language over tenant residency/admin language
    if any(term in q for term in ["lease", "leasing", "rent", "rental", "tenant"]):
        if doc_type == "ccrs":
            boost += 0.08

        if any(term in text for term in ["lease", "leased", "leasing", "rented", "rental"]):
            boost += 0.10

        if "proof of residency" in text or "driver's license" in text:
            boost -= 0.10

    # Violations / enforcement questions
    if any(term in q for term in ["violate", "violation", "violations", "fine", "fines", "penalty", "penalties", "enforcement", "hearing", "notice"]):
        if any(term in text for term in ["violation", "violations", "fine", "fines", "hearing", "notice", "remove", "fifteen (15) days"]):
            boost += 0.16

        if "pool" in text and not any(term in q for term in ["pool", "clubhouse"]):
            boost -= 0.08

    return boost


def boost_score(query: str, item: dict, analysis: dict | None = None) -> float:
    q = query.lower()
    doc_type = item.get("doc_type", "")
    boost = 0.0

    if analysis:
        preferred_doc_types = set(analysis.get("preferred_doc_types", []))
        if item.get("doc_type") in preferred_doc_types:
            boost += 0.05

    # Global boosts
    if any(term in q for term in ["annual meeting", "members meeting", "special meeting"]):
        if doc_type == "bylaws":
            boost += 0.08

    if any(term in q for term in ["lease", "rent", "tenant", "leasing"]):
        if doc_type == "ccrs":
            boost += 0.08

    if any(term in q for term in ["trash", "garbage", "recycling", "recycle"]):
        if doc_type == "policy":
            boost += 0.08

    if any(term in q for term in ["assessment", "dues", "late fee", "delinquent"]):
        if doc_type in {"policy", "ccrs", "bylaws"}:
            boost += 0.05

    if any(term in q for term in ["parking", "park", "vehicle", "van", "overnight"]):
        if doc_type in {"ccrs", "policy"}:
            boost += 0.06

    quality = item.get("quality_score", 0.5)
    boost += quality * 0.05

    important_hits = item.get("important_hits", 0)
    boost += min(important_hits, 5) * 0.01

    boost += lexical_overlap_score(query, item)
    boost += section_title_score(query, item)

    # HOA-specific overrides
    if HOA_NAME == "milestone":
        boost = boost_score_milestone(query, item, boost)
    elif HOA_NAME == "arora":
        boost = boost_score_arora(query, item, boost)

    return item["score"] + boost

def rerank_results(query: str, results: list[dict], analysis: dict | None = None) -> list[dict]:
    reranked = []
    for r in results:
        r = dict(r)
        r["boosted_score"] = boost_score(query, r, analysis=analysis)
        reranked.append(r)
    reranked.sort(key=lambda x: x["boosted_score"], reverse=True)
    return reranked


def dedupe_results(results: list[dict]) -> list[dict]:
    best_by_page = {}

    for r in results:
        key = (r["source_file"], r.get("page"))
        existing = best_by_page.get(key)
        if existing is None or r["boosted_score"] > existing["boosted_score"]:
            best_by_page[key] = r

    deduped = sorted(best_by_page.values(), key=lambda x: x["boosted_score"], reverse=True)
    return deduped


def limit_per_document(results: list[dict], max_per_doc: int = MAX_PER_DOCUMENT) -> list[dict]:
    counts = {}
    limited = []

    for r in results:
        doc = r["source_file"]
        counts.setdefault(doc, 0)

        if counts[doc] >= max_per_doc:
            continue

        limited.append(r)
        counts[doc] += 1

    return limited


def filter_results(results: list[dict]) -> list[dict]:
    filtered = []
    for r in results:
        score = r.get("score", 0)
        quality = r.get("quality_score", 0)

        if score >= MIN_CHUNK_SCORE or (quality > 0.7 and score >= 0.25):
            filtered.append(r)

    return filtered


def build_user_prompt(question: str, retrieved_chunks: list[dict]) -> str:
    excerpts = []
    for i, chunk in enumerate(retrieved_chunks, start=1):
        page = chunk.get("page")
        page_label = f"p.{page}" if page else "page unknown"
        section_title = chunk.get("section_title")
        section_line = f"Section: {section_title}\n" if section_title else ""

        excerpts.append(
            f"[Excerpt {i}]\n"
            f"Source: {chunk['source_file']} {page_label}\n"
            f"{section_line}"
            f"Similarity: {chunk['score']:.3f}\n"
            f"Text: {chunk['text']}\n"
        )

    return (
        f"Question:\n{question.strip()}\n\n"
        f"Retrieved HOA excerpts:\n\n"
        + "\n".join(excerpts)
    )


def call_ollama(system_prompt: str, user_prompt: str, model: str = CHAT_MODEL) -> str:
    payload = json.dumps(
        {
            "model": model,
            "stream": False,
            "messages": [
                {"role": "system", "content": system_prompt},
                {"role": "user", "content": user_prompt},
            ],
        }
    ).encode("utf-8")

    req = urllib.request.Request(
        OLLAMA_URL,
        data=payload,
        headers={"Content-Type": "application/json"},
        method="POST",
    )

    try:
        with urllib.request.urlopen(req, timeout=180) as resp:
            data = json.loads(resp.read())
            return data["message"]["content"].strip()
    except urllib.error.URLError as e:
        print(f"[error] Could not reach Ollama at {OLLAMA_URL}")
        print(f"[error] {e}")
        sys.exit(1)


def append_debug_log(
    question: str,
    retrieved: list[dict],
    answer: str,
    confidence: str,
    system_prompt: str | None = None,
    user_prompt: str | None = None,
    analysis: dict | None = None,
) -> None:
    LOG_DIR.mkdir(parents=True, exist_ok=True)

    record = {
        "timestamp": datetime.now().isoformat(timespec="seconds"),
        "question": question,
        "confidence": confidence,
        "top_score": retrieved[0]["score"] if retrieved else None,
        "avg_score_top3": (
            sum(r["score"] for r in retrieved[:3]) / min(len(retrieved), 3)
            if retrieved else None
        ),
        "retrieved": [
            {
                "source_file": r.get("source_file"),
                "page": r.get("page"),
                "score": r.get("score"),
                "boosted_score": r.get("boosted_score"),
                "doc_type": r.get("doc_type"),
                "chunk_index": r.get("chunk_index"),
                "snippet": r.get("text", "")[:500],
            }
            for r in retrieved
        ],
        "answer": answer,
    }

    if analysis is not None:
        record["query_analysis"] = analysis

    if system_prompt is not None and user_prompt is not None:
        record["prompt"] = {
            "system": system_prompt,
            "user": user_prompt,
        }

    with DEBUG_LOG_PATH.open("a", encoding="utf-8") as f:
        f.write(json.dumps(record, ensure_ascii=False) + "\n")


def print_debug_excerpts(results: list[dict]) -> None:
    if not DEBUG_SHOW_EXCERPTS:
        return

    print("\nRetrieved excerpts:")
    for i, r in enumerate(results, start=1):
        page = f"p.{r['page']}" if r.get("page") else "page unknown"
        snippet = r["text"][:300].replace("\n", " ")
        print(
            f"{i}. {r['source_file']} {page} "
            f"(score={r['score']:.3f}, boosted={r['boosted_score']:.3f})"
        )
        print(f"   {snippet}...")


def print_sources(results: list[dict]) -> None:
    print("\nSources used:")
    for r in results:
        page = f" p.{r['page']}" if r.get("page") else ""
        print(
            f"- {r['source_file']}{page} "
            f"(score={r['score']:.3f}, boosted={r['boosted_score']:.3f})"
        )

def validate_dataset() -> None:
    if not INDEX_DIR.exists():
        raise FileNotFoundError(f"HOA dataset not found: {DATASET_DIR}")
    if not FAISS_PATH.exists() or not META_PATH.exists():
        raise FileNotFoundError(
            f"Index files not found for HOA '{HOA_NAME}'. Run ingest_hoa_docs.py for that HOA first."
        )

def main() -> None:
    print("HOA AI")
    print(f"Model: {CHAT_MODEL}")
    print("Type 'quit' to exit.\n")

    validate_dataset()
    index, meta = load_index()
    embed_model = SentenceTransformer(EMBED_MODEL)

    while True:
        try:
            user_input = input("You: ").strip()
        except (EOFError, KeyboardInterrupt):
            print("\nGoodbye.")
            break

        if not user_input:
            continue
        if user_input.lower() == "quit":
            print("Goodbye.")
            break

        analysis = analyze_query(user_input)
        normalized_input = analysis["normalized_question"]

        retrieved = retrieve_with_analysis(analysis, embed_model, index, meta, top_k=TOP_K)
        retrieved = rerank_results(normalized_input, retrieved, analysis=analysis)
        retrieved = dedupe_results(retrieved)
        retrieved = filter_results(retrieved)

        if not retrieved:
            answer = "I couldn’t find anything relevant in the HOA documents."
            print(f"\nAssistant:\n{answer}\n")
            append_debug_log(user_input, [], answer, "none")
            continue

        retrieved.sort(key=lambda x: x["boosted_score"], reverse=True)
        retrieved = limit_per_document(retrieved, max_per_doc=MAX_PER_DOCUMENT)

        top_score = retrieved[0]["score"]
        avg_score = sum(r["score"] for r in retrieved[:2]) / min(len(retrieved), 2)

        high_conf = top_score >= 0.50 and avg_score >= 0.40
        med_conf = top_score >= 0.34

        if not med_conf:
            answer = "I couldn’t find a strong enough match in the HOA documents to answer confidently."
            print(f"\nAssistant:\n{answer}\n")
            append_debug_log(user_input, retrieved, answer, "low", analysis=analysis)
            continue

        retrieved = retrieved[:MAX_CONTEXT_CHUNKS]

        print_debug_excerpts(retrieved)

        user_prompt = build_user_prompt(user_input, retrieved)

        final_system_prompt = SYSTEM_PROMPT
        confidence = "high" if high_conf else "medium"
        if not high_conf:
            final_system_prompt += (
                "\n\nIMPORTANT: The retrieved excerpts are only moderately relevant. "
                "Be cautious and explicitly state uncertainty."
            )

        answer = call_ollama(final_system_prompt, user_prompt)

        print(f"\nAssistant:\n{answer}\n")
        print_sources(retrieved)
        print("")

        append_debug_log(
            user_input,
            retrieved,
            answer,
            confidence,
            system_prompt=final_system_prompt,
            user_prompt=user_prompt,
            analysis=analysis,
        )


if __name__ == "__main__":
    main()